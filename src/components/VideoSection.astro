---
interface Props {
  title: string;
  text: string;
  /** YouTube/Vimeo/Tella-lenke, embed-URL, eller sti til .mp4 (f.eks. /video/demo.mp4) */
  src: string;
  eyebrow?: string;
  type?: 'youtube' | 'vimeo' | 'tella' | 'file';
  /** Forbeholdsbilde ved selvhostet video */
  poster?: string;
  class?: string;
}

const { title, text, src, eyebrow, type, poster, class: className } = Astro.props;

function resolveVideo(
  url: string,
  explicitType?: Props['type']
): { kind: 'iframe' | 'video'; embedUrl: string } {
  const isFile =
    explicitType === 'file' ||
    /\.(mp4|webm|ogg)(\?|$)/i.test(url) ||
    (url.startsWith('/') && !url.includes('youtube') && !url.includes('vimeo'));

  if (isFile) {
    return { kind: 'video', embedUrl: url };
  }

  const youtubeMatch = url.match(
    /(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/
  );
  if (youtubeMatch || explicitType === 'youtube') {
    const id = youtubeMatch?.[1] ?? url.split('/').pop();
    return {
      kind: 'iframe',
      embedUrl: `https://www.youtube.com/embed/${id}?rel=0`
    };
  }

  const vimeoMatch = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (vimeoMatch || explicitType === 'vimeo') {
    const id = vimeoMatch?.[1] ?? url.split('/').pop();
    return {
      kind: 'iframe',
      embedUrl: `https://player.vimeo.com/video/${id}`
    };
  }

  const isTella =
    explicitType === 'tella' ||
    url.includes('tella.tv') ||
    url.includes('effektdigital.no');

  if (isTella) {
    const base = url.replace(/\/embed\/?$/, '').replace(/\/view\/?$/, '').replace(/\/?$/, '');
    return { kind: 'iframe', embedUrl: `${base}/embed` };
  }

  if (url.includes('youtube.com/embed') || url.includes('player.vimeo.com')) {
    return { kind: 'iframe', embedUrl: url };
  }

  return { kind: 'video', embedUrl: url };
}

const video = resolveVideo(src, type);
---

<section class:list={['w-full', className]}>
  <div class="mx-auto max-w-3xl text-center">
    {eyebrow && (
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-accent">
        {eyebrow}
      </p>
    )}
    <h2 class="text-4xl font-semibold leading-none tracking-[-0.06em] sm:text-5xl lg:text-6xl">
      {title}
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-xl leading-relaxed text-muted">
      {text}
    </p>
  </div>

  <div class="mx-auto mt-10 max-w-4xl [filter:drop-shadow(0_25px_25px_rgb(28_25_23/0.05))]">
    <div class="rounded-[2rem] bg-line p-px">
      <div class="relative aspect-video w-full overflow-hidden rounded-[calc(2rem-1px)] bg-ink leading-none">
        {video.kind === 'iframe' ? (
          <iframe
            class="absolute left-1/2 top-1/2 block h-[calc(100%+4px)] w-[calc(100%+4px)] -translate-x-1/2 -translate-y-1/2 border-0"
            src={video.embedUrl}
            title={title}
            loading="eager"
            scrolling="no"
            allow="autoplay; fullscreen; accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          />
        ) : (
          <video
            class="absolute left-1/2 top-1/2 block h-[calc(100%+4px)] w-[calc(100%+4px)] -translate-x-1/2 -translate-y-1/2 object-cover"
            src={video.embedUrl}
            poster={poster}
            controls
            playsinline
            preload="metadata"
          >
            <track kind="captions" />
          </video>
        )}
      </div>
    </div>
  </div>
</section>
