---
interface Props {
  formName?: string;
  heading?: string;
  intro?: string;
  submitLabel?: string;
  successPath?: string;
}

const {
  formName = 'contact',
  heading = 'Send oss en melding',
  intro = 'Vi svarer vanligvis innen én arbeidsdag.',
  submitLabel = 'Send melding',
  successPath = '/takk/',
} = Astro.props;

const inputClass =
  'w-full rounded-2xl border border-line bg-sand px-5 py-3.5 text-ink outline-none transition focus:border-accent focus:ring-2 focus:ring-accent-soft';
const labelClass = 'mb-2 block text-sm font-semibold text-ink';
---

<form
  name={formName}
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="contact-form grid gap-5"
>
  <input type="hidden" name="form-name" value={formName} />

  <p class="hidden" aria-hidden="true">
    <label>
      Ikke fyll ut dette feltet
      <input name="bot-field" tabindex="-1" autocomplete="off" />
    </label>
  </p>

  {heading && <h2 class="text-2xl font-semibold tracking-[-0.04em]">{heading}</h2>}
  {intro && <p class="-mt-2 text-muted">{intro}</p>}

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label class={labelClass} for={`${formName}-fornavn`}>Fornavn</label>
      <input
        class={inputClass}
        type="text"
        id={`${formName}-fornavn`}
        name="fornavn"
        autocomplete="given-name"
        required
      />
    </div>
    <div>
      <label class={labelClass} for={`${formName}-etternavn`}>Etternavn</label>
      <input
        class={inputClass}
        type="text"
        id={`${formName}-etternavn`}
        name="etternavn"
        autocomplete="family-name"
        required
      />
    </div>
  </div>

  <div>
    <label class={labelClass} for={`${formName}-epost`}>E-post</label>
    <input
      class={inputClass}
      type="email"
      id={`${formName}-epost`}
      name="epost"
      autocomplete="email"
      required
    />
  </div>

  <div>
    <label class={labelClass} for={`${formName}-melding`}>Mer informasjon</label>
    <textarea
      class:list={[inputClass, 'min-h-36 resize-y']}
      id={`${formName}-melding`}
      name="melding"
      rows="5"
      required
      placeholder="Fortell kort om bedriften, utfordringen og hva dere ønsker hjelp med."
    />
  </div>

  <p class="hidden text-sm text-red-700" data-form-error>
    Noe gikk galt. Prøv igjen, eller send e-post til hans@effektdigital.no.
  </p>

  <button
    type="submit"
    class="inline-flex w-full justify-center rounded-full bg-ink px-6 py-4 text-sm font-semibold text-white transition hover:bg-ink/90 disabled:opacity-60 sm:w-auto"
  >
    {submitLabel}
  </button>
</form>

<script define:vars={{ formName, successPath }}>
  const form = document.querySelector(`form.contact-form[name="${formName}"]`);
  const errorEl = form?.querySelector('[data-form-error]');
  const submitBtn = form?.querySelector('button[type="submit"]');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    errorEl?.classList.add('hidden');
    submitBtn?.setAttribute('disabled', 'true');

    try {
      const body = new URLSearchParams(new FormData(form)).toString();
      await fetch('/kontakt/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body,
      });
      window.location.href = successPath;
    } catch {
      errorEl?.classList.remove('hidden');
      submitBtn?.removeAttribute('disabled');
    }
  });
</script>
