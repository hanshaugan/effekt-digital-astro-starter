---
interface Props {
  title?: string;
  text?: string;
  tools?: string[];
  ctaLabel?: string;
  ctaHref?: string;
  class?: string;
}

const defaultTools = [
  'HubSpot',
  'Attio',
  'Pipedrive',
  'Dult',
  'Loops',
  'Fillout',
  'Twentythree',
  'Make'
];

const {
  title = 'Teknologi vi ofte jobber med',
  text = 'Vi hjelper kunder å velge og sette sammen riktig stack basert på arbeidsflyt, modenhet og salgsprosess.',
  tools = defaultTools,
  ctaLabel = 'Se hvordan vi tenker rundt moderne sales-tech',
  ctaHref = '/tjenester/',
  class: className
} = Astro.props;
---

<section class:list={['w-full', className]} aria-labelledby="tech-stack-heading">
  <div
    class="rounded-[2.25rem] border border-line bg-white px-8 py-16 sm:px-12 sm:py-20 lg:px-16 lg:py-24"
  >
    <div class="mx-auto max-w-3xl text-center">
      <h2
        id="tech-stack-heading"
        class="text-4xl font-semibold leading-none tracking-[-0.06em] text-ink sm:text-5xl lg:text-6xl"
      >
        {title}
      </h2>
      <p class="mx-auto mt-8 max-w-2xl text-xl leading-relaxed text-muted">
        {text}
      </p>
    </div>

    <p
      class="mx-auto mt-14 max-w-5xl text-center text-lg font-medium leading-loose tracking-[-0.02em] text-ink sm:mt-16 sm:text-xl sm:leading-relaxed lg:mt-20"
    >
      {tools.join(' · ')}
    </p>

    <div class="mt-14 flex justify-center sm:mt-16 lg:mt-20">
      <a
        href={ctaHref}
        class="rounded-full border border-line bg-sand px-7 py-4 text-sm font-semibold text-ink transition-colors hover:border-ink/20 hover:bg-sand-2"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</section>
