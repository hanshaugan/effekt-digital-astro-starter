---
import BaseLayout from '../layouts/BaseLayout.astro';
import CrmHelsesjekkForm from '../components/CrmHelsesjekkForm.astro';
import { absoluteUrl } from '../lib/site';
import {
  organizationSchema,
  schemaGraph,
  webPageSchema,
  websiteSchema,
} from '../lib/schema';

const title = 'CRM-helsesjekk – Effekt Digital';
const description =
  'Gratis vurdering av CRM og salgsprosess: datakvalitet, oppfølging, pipeline, adopsjon og automasjon for B2B-bedrifter.';
const url = absoluteUrl('/crm-helsesjekk/');
const schema = schemaGraph(
  organizationSchema(),
  websiteSchema(),
  webPageSchema({ title, description, url }),
);
---
<BaseLayout {title} {description} {schema}>
  <main class="grid gap-12 lg:grid-cols-[1fr_0.85fr] lg:items-start">
    <section>
      <p class="mb-5 inline-flex rounded-full bg-accent-soft px-4 py-2 text-sm font-semibold text-accent">Gratis vurdering</p>
      <h1 class="text-6xl font-semibold leading-[0.94] tracking-[-0.075em] sm:text-7xl">Fungerer CRM-et deres slik det burde?</h1>
      <p class="mt-8 max-w-2xl text-xl leading-relaxed text-muted">Få en enkel vurdering av hvor salgsprosessen lekker: datakvalitet, oppfølging, pipeline, adopsjon, automasjon og verktøyflyt.</p>
      <ul class="mt-10 grid gap-3 text-lg text-muted">
        <li>• Hvor mister dere momentum i salget?</li>
        <li>• Hva bør automatiseres?</li>
        <li>• Hvilke CRM-felter og dashboards er faktisk nyttige?</li>
        <li>• Hvordan kan selgerne få mer verdi ut av systemet?</li>
      </ul>
    </section>
    <aside class="rounded-[2rem] border border-line bg-white p-7">
      <CrmHelsesjekkForm />
    </aside>
  </main>
</BaseLayout>
