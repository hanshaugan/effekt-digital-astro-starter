---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} – Effekt Digital`} description={post.data.description}>
  <article class="mx-auto max-w-3xl">
    <a href="/blog/" class="text-sm font-semibold text-accent">← Tilbake til innsikt</a>
    <p class="mt-10 text-sm font-semibold uppercase tracking-[0.18em] text-accent">{post.data.category}</p>
    <h1 class="mt-4 text-5xl font-semibold leading-none tracking-[-0.07em] sm:text-6xl">{post.data.title}</h1>
    <p class="mt-6 text-xl leading-relaxed text-muted">{post.data.description}</p>
    <div class="prose prose-stone mt-10 max-w-none prose-headings:tracking-[-0.04em] prose-a:text-accent">
      <Content />
    </div>
  </article>
</BaseLayout>
