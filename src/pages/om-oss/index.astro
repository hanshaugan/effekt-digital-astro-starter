---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { SITE, absoluteUrl } from '../../lib/site';
import {
  organizationSchema,
  schemaGraph,
  webPageSchema,
  websiteSchema,
} from '../../lib/schema';

const title = 'Om oss – Effekt Digital';
const description =
  'Effekt Digital er en salgs- og vekstpartner for B2B-bedrifter. Vi hjelper med CRM, salgsprosess, AI og praktisk implementering.';
const url = absoluteUrl('/om-oss/');
const schema = schemaGraph(
  organizationSchema(),
  websiteSchema(),
  webPageSchema({ title, description, url }),
);

const principles = [
  {
    title: 'Vi blir en del av teamet ditt',
    text: 'Målet er at dere skal kunne eie prosess og verktøy over tid. Vi bygger sammen med dere — med opplæring og støtte underveis.',
  },
  {
    title: 'Strategi før taktikk',
    text: 'Vi starter med målgruppe, salgsprosess og flaskehalser. Deretter velger vi teknologi og arbeidsflyt som faktisk støtter hvordan dere selger.',
  },
  {
    title: 'Support og opplæring',
    text: 'Workshops, 1-til-1 og praktisk trening i CRM og salgsrutiner. Løsningen skal fungere i hverdagen — ikke bare i en presentasjon.',
  },
  {
    title: 'Vi skal forstå businessen din',
    text: 'Bransje, konkurransesituasjon og vekstambisjoner påvirker hva som gir mening. Vi tar oss tid til å forstå konteksten før vi anbefaler tiltak.',
  },
];

const partners = [
  ['HubSpot', 'CRM, marketing automation og salgsverktøy for vekstbedrifter.', 'https://www.hubspot.com'],
  ['Pipedrive', 'CRM med fokus på pipeline, aktiviteter og enkelhet for salgsteam.', 'https://www.pipedrive.com'],
  ['Dult', 'Norsk CRM-alternativ for team som vil ha en enkel og moderne salgsplattform.', 'https://dult.io'],
  ['TwentyThree', 'Video- og webinarplattform for profesjonell videomarkedsføring og leadgenerering.', 'https://www.twentythree.com'],
  ['ProspectFinder', 'AI-drevet prospektering og lead-kvalifisering for B2B-salg.', 'https://prospectfinder.ai'],
];
---

<BaseLayout {title} {description} {schema}>
  <main>
    <section class="grid gap-12 lg:grid-cols-[1fr_0.9fr] lg:items-end">
      <div>
        <p class="mb-6 inline-flex rounded-full bg-accent-soft px-4 py-2 text-sm font-semibold text-accent">
          Om Effekt Digital
        </p>
        <h1 class="max-w-3xl text-6xl font-semibold leading-[0.94] tracking-[-0.075em] sm:text-7xl">
          Lidenskap for salg og vekst.
        </h1>
        <p class="mt-8 max-w-2xl text-xl leading-relaxed text-muted">
          Det handler ikke om oss — men om dine planer, mål og ambisjoner. Som salgspartner hjelper vi
          B2B-bedrifter med å bygge salgsprosesser, CRM og arbeidsflyt som gir fart i hverdagen.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/kontakt/" class="rounded-full bg-ink px-6 py-4 text-sm font-semibold text-white">
            Ta kontakt
          </a>
          <a href="/landingssider/vekstpilot/" class="rounded-full border border-line px-6 py-4 text-sm font-semibold">
            Se VekstPilot
          </a>
        </div>
      </div>
      <aside class="rounded-[2rem] border border-line bg-white p-7">
        <p class="text-sm font-semibold uppercase tracking-wider text-accent">Kort fortalt</p>
        <ul class="mt-5 space-y-4 text-muted">
          <li>• Konsulenthus innen salg, CRM og sales-tech</li>
          <li>• Spesialisert på B2B med vekstambisjoner</li>
          <li>• Systemagnostisk — HubSpot, Pipedrive, Dult og mer</li>
          <li>• Basert i Jessheim, jobber med kunder i hele Norge</li>
        </ul>
      </aside>
    </section>

    <section class="mt-28">
      <SectionHeading
        eyebrow="Hvordan vi jobber"
        title="Dine utfordringer er vår motivasjon."
        text="Vi kombinerer salgsforståelse med praktisk implementering. Ikke store strategidokumenter — men arbeidsflyt som selgerne faktisk bruker."
      />
      <div class="grid gap-4 md:grid-cols-2">
        {
          principles.map(({ title, text }) => (
            <article class="rounded-[1.75rem] border border-line bg-white p-7">
              <h2 class="text-2xl font-semibold tracking-[-0.04em]">{title}</h2>
              <p class="mt-4 text-muted">{text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mt-28 rounded-[2rem] bg-ink px-8 py-10 text-white lg:px-12 lg:py-12">
      <h2 class="max-w-2xl text-4xl font-semibold tracking-[-0.05em]">Moderne salgsprosesser — ikke bare flere verktøy.</h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/65">
        Mange bedrifter har CRM, men mangler struktur, oppfølging og adopsjon. Vi hjelper med å koble
        sammen teknologi, innhold, salgsaktiviteter og kultur — med VekstPilot som rammeverk når det
        passer.
      </p>
    </section>

    <section class="mt-28">
      <SectionHeading
        eyebrow="Partnere"
        title="Verktøy vi jobber med."
        text="Vi er ikke bundet til én plattform. Her er noen av de vi oftest anbefaler og implementerer."
      />
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          partners.map(([name, text, url]) => (
            <article class="rounded-[1.75rem] bg-sand p-7">
              <h2 class="text-2xl font-semibold tracking-[-0.04em]">
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="transition hover:text-accent"
                >
                  {name}
                </a>
              </h2>
              <p class="mt-3 text-muted">{text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mt-28 rounded-[2rem] border border-line bg-white p-8 lg:p-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
        <div>
          <h2 class="text-4xl font-semibold tracking-[-0.05em]">Klar for en prat?</h2>
          <p class="mt-4 max-w-xl text-lg text-muted">
            Fortell oss om bedriften, salgsprosessen og hva dere ønsker å få til. Vi tar en uforpliktende
            gjennomgang og ser om det er et match.
          </p>
          <p class="mt-6 text-sm text-muted">
            {SITE.legalName} · {SITE.address.street}, {SITE.address.postalCode} {SITE.address.city}
          </p>
        </div>
        <a href="/kontakt/" class="inline-flex shrink-0 rounded-full bg-ink px-6 py-4 text-sm font-semibold text-white">
          Book en prat
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
