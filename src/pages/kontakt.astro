---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Kontakt – Effekt Digital">
  <main class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-accent">Kontakt</p>
      <h1 class="text-5xl font-semibold leading-none tracking-[-0.07em] sm:text-6xl">Book en prat om CRM, AI og salgsflyt.</h1>
      <p class="mt-7 text-xl leading-relaxed text-muted">Fortell kort hva dere jobber med, så kan vi se på hvordan dere kan få bedre struktur, oppfølging og flyt fra lead til kunde.</p>
    </div>
    <div class="rounded-[2rem] border border-line bg-white p-7">
      <p class="mb-5 text-muted">Bytt gjerne dette ut med en Fillout embed.</p>
      <a class="inline-flex rounded-full bg-ink px-6 py-4 text-sm font-semibold text-white" href="mailto:hans@effektdigital.no">hans@effektdigital.no</a>
    </div>
  </main>
</BaseLayout>
