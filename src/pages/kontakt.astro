---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE, absoluteUrl } from '../lib/site';
import {
  organizationSchema,
  schemaGraph,
  webPageSchema,
  websiteSchema,
} from '../lib/schema';

const title = 'Kontakt – Effekt Digital';
const description =
  'Book en prat om CRM, AI og salgsflyt. Effekt Digital hjelper B2B-selskaper med moderne salgsprosesser og sales-tech.';
const url = absoluteUrl('/kontakt/');
const schema = schemaGraph(
  organizationSchema(),
  websiteSchema(),
  webPageSchema({ title, description, url }),
);
---

<BaseLayout {title} {description} {schema}>
  <main class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-accent">Kontakt</p>
      <h1 class="text-5xl font-semibold leading-none tracking-[-0.07em] sm:text-6xl">
        Book en prat om CRM, AI og salgsflyt.
      </h1>
      <p class="mt-7 text-xl leading-relaxed text-muted">
        Fortell kort hva dere jobber med, så ser vi på hvordan dere kan få bedre struktur, oppfølging
        og flyt fra lead til kunde.
      </p>

      <div class="mt-10 grid gap-4">
        {
          SITE.calendlyUrl && (
            <a
              href={SITE.calendlyUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between rounded-[1.75rem] border border-line bg-white p-6 transition hover:-translate-y-0.5"
            >
              <div>
                <p class="font-semibold">Book møte direkte</p>
                <p class="mt-1 text-sm text-muted">Velg tid i kalenderen som passer deg.</p>
              </div>
              <span class="text-sm font-semibold text-accent">→</span>
            </a>
          )
        }

        <a
          href={`mailto:${SITE.email}`}
          class="flex items-center justify-between rounded-[1.75rem] border border-line bg-white p-6 transition hover:-translate-y-0.5"
        >
          <div>
            <p class="font-semibold">Send e-post</p>
            <p class="mt-1 text-sm text-muted">{SITE.email}</p>
          </div>
          <span class="text-sm font-semibold text-accent">→</span>
        </a>
      </div>
    </div>

    <aside class="rounded-[2rem] border border-line bg-white p-7 lg:p-8">
      <ContactForm />
    </aside>
  </main>
</BaseLayout>
