---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl } from '../../lib/site';
import {
  articleSchema,
  organizationSchema,
  schemaGraph,
  webPageSchema,
  websiteSchema,
} from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const title = `${post.data.title} – Effekt Digital`;
const description = post.data.description;
const url = absoluteUrl(`/blogg/${post.id}/`);
const schema = schemaGraph(
  organizationSchema(),
  websiteSchema(),
  webPageSchema({ title, description, url }),
  articleSchema({
    title: post.data.title,
    description,
    url,
    pubDate: post.data.pubDate,
    author: post.data.author,
    image: post.data.image,
  }),
);
---

<BaseLayout
  title={title}
  description={description}
  image={post.data.image}
  type="article"
  schema={schema}
>
  <article class="mx-auto max-w-3xl">
    <a href="/blogg/" class="text-sm font-semibold text-accent">← Tilbake til bloggen</a>
    <p class="mt-10 text-sm font-semibold uppercase tracking-[0.18em] text-accent">{post.data.category}</p>
    <h1 class="mt-4 text-5xl font-semibold leading-none tracking-[-0.07em] sm:text-6xl">{post.data.title}</h1>
    <p class="mt-6 text-xl leading-relaxed text-muted">{post.data.description}</p>
    {post.data.author && <p class="mt-4 text-sm text-muted">Av {post.data.author}</p>}
    <div class="prose prose-stone mt-10 max-w-none prose-headings:tracking-[-0.04em] prose-a:text-accent">
      <Content />
    </div>
  </article>
</BaseLayout>
